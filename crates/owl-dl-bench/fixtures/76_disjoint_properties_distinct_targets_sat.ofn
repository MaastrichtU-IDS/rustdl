Ontology(<http://rustdl.test/fixture/76_disjoint_properties_distinct_targets_sat>
    Declaration(Class(:Test))
    Declaration(ObjectProperty(:r))
    Declaration(ObjectProperty(:s))
    Declaration(NamedIndividual(:a))
    Declaration(NamedIndividual(:b))
    Declaration(NamedIndividual(:c))
    DisjointObjectProperties(:r :s)
    DifferentIndividuals(:b :c)
    ObjectPropertyAssertion(:r :a :b)
    ObjectPropertyAssertion(:s :a :c)
    EquivalentClasses(:Test ObjectOneOf(:a))
)
