Prefix(:=<http://rustdl.test/>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)

Ontology(<http://rustdl.test/fixture/25_parent_childless_unsat>
    Declaration(Class(:Person))
    Declaration(Class(:Parent))
    Declaration(Class(:Childless))
    Declaration(Class(:Test))
    Declaration(ObjectProperty(:hasChild))
    EquivalentClasses(:Parent ObjectSomeValuesFrom(:hasChild :Person))
    EquivalentClasses(:Childless ObjectAllValuesFrom(:hasChild owl:Nothing))
    EquivalentClasses(:Test ObjectIntersectionOf(:Parent :Childless))
)
