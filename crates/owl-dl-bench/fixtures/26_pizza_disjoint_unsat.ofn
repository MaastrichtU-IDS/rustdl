Prefix(:=<http://rustdl.test/>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)

Ontology(<http://rustdl.test/fixture/26_pizza_disjoint_unsat>
    Declaration(Class(:Veg))
    Declaration(Class(:Meat))
    Declaration(Class(:Test))
    Declaration(ObjectProperty(:hasTopping))
    DisjointClasses(:Veg :Meat)
    EquivalentClasses(:Test
        ObjectIntersectionOf(
            ObjectAllValuesFrom(:hasTopping :Veg)
            ObjectSomeValuesFrom(:hasTopping :Meat)
        )
    )
)
