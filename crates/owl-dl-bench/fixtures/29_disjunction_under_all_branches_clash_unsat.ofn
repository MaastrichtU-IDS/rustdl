    Declaration(Class(:A))
    Declaration(Class(:B))
    Declaration(Class(:Test))
    Declaration(ObjectProperty(:r))
    EquivalentClasses(:Test
        ObjectIntersectionOf(
            ObjectSomeValuesFrom(:r :A)
            ObjectAllValuesFrom(:r ObjectUnionOf(ObjectComplementOf(:A) :B))
            ObjectAllValuesFrom(:r ObjectComplementOf(:B))
