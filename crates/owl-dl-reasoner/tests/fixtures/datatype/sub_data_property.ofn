Prefix(:=<http://t/>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Ontology(<http://t/sub_data_property>
    Declaration(Class(:A))
    Declaration(Class(:B))
    Declaration(DataProperty(:specific))
    Declaration(DataProperty(:general))
    SubDataPropertyOf(:specific :general)
    SubClassOf(:A DataSomeValuesFrom(:specific xsd:integer))
    SubClassOf(DataSomeValuesFrom(:general xsd:integer) :B)
)
